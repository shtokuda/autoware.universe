<?xml version="1.0"?>
<class_libraries>
  <library path="autoware_trajectory_optimizer_plugins">
    <class type="autoware::trajectory_optimizer::plugin::TrajectoryPointFixer"
          base_class_type="autoware::trajectory_optimizer::plugin::TrajectoryOptimizerPluginBase">
      <description>
        Removes invalid trajectory points (NaN, Inf, close proximity)
      </description>
    </class>
    <class type="autoware::trajectory_optimizer::plugin::TrajectoryKinematicFeasibilityEnforcer"
          base_class_type="autoware::trajectory_optimizer::plugin::TrajectoryOptimizerPluginBase">
      <description>
        Kinematic Feasibility Enforcer plugin. Enforces Ackermann steering geometry and yaw rate constraints on trajectory points using forward-propagating adjustment from ego pose. Ensures trajectories are kinematically feasible before QP smoothing.
      </description>
    </class>
    <class type="autoware::trajectory_optimizer::plugin::TrajectoryQPSmoother"
          base_class_type="autoware::trajectory_optimizer::plugin::TrajectoryOptimizerPluginBase">
      <description>
        QP-based trajectory smoother with fidelity and smoothness constraints
      </description>
    </class>
    <class type="autoware::trajectory_optimizer::plugin::TrajectoryEBSmootherOptimizer"
          base_class_type="autoware::trajectory_optimizer::plugin::TrajectoryOptimizerPluginBase">
      <description>
        Elastic Band trajectory smoother for path optimization
      </description>
    </class>
    <class type="autoware::trajectory_optimizer::plugin::TrajectorySplineSmoother"
          base_class_type="autoware::trajectory_optimizer::plugin::TrajectoryOptimizerPluginBase">
      <description>
        Akima spline-based trajectory interpolation and smoothing
      </description>
    </class>
    <class type="autoware::trajectory_optimizer::plugin::TrajectoryVelocityOptimizer"
          base_class_type="autoware::trajectory_optimizer::plugin::TrajectoryOptimizerPluginBase">
      <description>
        Velocity profile optimization with lateral acceleration limits and jerk filtering
      </description>
    </class>
    <class type="autoware::trajectory_optimizer::plugin::TrajectoryExtender"
          base_class_type="autoware::trajectory_optimizer::plugin::TrajectoryOptimizerPluginBase">
      <description>
        Extends trajectory backward with ego vehicle history
      </description>
    </class>
    <class type="autoware::trajectory_optimizer::plugin::TrajectoryMPTOptimizer"
          base_class_type="autoware::trajectory_optimizer::plugin::TrajectoryOptimizerPluginBase">
      <description>
        MPT (Model Predictive Trajectory) optimizer. Optimizes trajectory geometry using QP-based optimization with adaptive corridor bounds. Refines paths within vehicle-centric constraints after kinematic feasibility and QP smoothing.
      </description>
    </class>
    <class type="autoware::trajectory_optimizer::plugin::TrajectoryTemporalMPTOptimizer"
          base_class_type="autoware::trajectory_optimizer::plugin::TrajectoryOptimizerPluginBase">
      <description>
        Temporal MPT optimizer plugin. Tracks a time-ordered reference trajectory using an acados MPC
        on a temporal kinematic bicycle model and overwrites the first N+1 points of the trajectory.
      </description>
    </class>
  </library>
  <library path="autoware_trajectory_modifier_plugins">
    <class type="autoware::trajectory_modifier::plugin::StopPointFixer"
          base_class_type="autoware::trajectory_modifier::plugin::TrajectoryModifierPluginBase">
      <description>
        Modifies the stop point of a trajectory to align with the obstacle stop point
      </description>
    </class>
    <class type="autoware::trajectory_modifier::plugin::ObstacleStop"
          base_class_type="autoware::trajectory_modifier::plugin::TrajectoryModifierPluginBase">
      <description>
        Modifies the trajectory to avoid obstacles by stopping
      </description>
    </class>
    <class type="autoware::trajectory_modifier::plugin::VelocityModifier"
          base_class_type="autoware::trajectory_modifier::plugin::TrajectoryModifierPluginBase">
      <description>
        Modifies the velocity of a trajectory to smooth the motion
      </description>
    </class>
    <class type="autoware::trajectory_modifier::plugin::SurroundObstacleStop"
          base_class_type="autoware::trajectory_modifier::plugin::TrajectoryModifierPluginBase">
      <description>
        Replaces the trajectory with zero velocity when obstacles surround a stopped ego vehicle
      </description>
    </class>
    <class type="autoware::trajectory_modifier::plugin::TrafficLightStop"
          base_class_type="autoware::trajectory_modifier::plugin::TrajectoryModifierPluginBase">
      <description>
        Modifies the trajectory to stop at traffic lights
      </description>
    </class>
  </library>
</class_libraries>
