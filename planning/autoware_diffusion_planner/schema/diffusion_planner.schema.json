{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Parameters for Diffusion Planner Node",
  "type": "object",
  "definitions": {
    "diffusion_planner_node": {
      "type": "object",
      "properties": {
        "plugins_path": {
          "type": "string",
          "default": "$(find-pkg-share autoware_tensorrt_plugins)/plugins/libautoware_tensorrt_plugins.so",
          "description": "Path to libautoware_tensorrt_plugins.so file for native TensorRT and ONNX Runtime TensorRT EP"
        },
        "model": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "default": "single_step",
              "enum": ["single_step", "multi_step"],
              "description": "Inference model type"
            },
            "args_path": {
              "type": "string",
              "default": "$(var data_path)/diffusion_planner/v5.0/args.json",
              "description": "Path to model argument/configuration file"
            },
            "backend": {
              "type": "string",
              "default": "tensorrt",
              "enum": ["tensorrt", "ort_cpu", "ort_cuda", "ort_tensorrt"],
              "description": "Inference backend. tensorrt uses the native TensorRT implementation; ort_cpu/ort_cuda/ort_tensorrt use ONNX Runtime with the corresponding execution provider."
            },
            "precision": {
              "type": "string",
              "default": "fp32",
              "enum": ["fp32", "fp16"],
              "description": "TensorRT engine precision"
            },
            "use_cuda_graph": {
              "type": "boolean",
              "default": true,
              "description": "Use CUDA Graph replay for TensorRT enqueue calls"
            },
            "single_step_model": {
              "type": "object",
              "properties": {
                "onnx_model_path": {
                  "type": "string",
                  "default": "$(var data_path)/diffusion_planner/v5.0/diffusion_planner.onnx",
                  "description": "Path to the single-step ONNX model file"
                }
              },
              "required": ["onnx_model_path"]
            },
            "multi_step_model": {
              "type": "object",
              "properties": {
                "encoder_onnx_model_path": {
                  "type": "string",
                  "default": "$(var data_path)/diffusion_planner/v5.0/diffusion_planner_encoder.onnx",
                  "description": "Path to the encoder ONNX model file"
                },
                "decoder_onnx_model_path": {
                  "type": "string",
                  "default": "$(var data_path)/diffusion_planner/v5.0/diffusion_planner_decoder.onnx",
                  "description": "Path to the decoder ONNX model file"
                },
                "turn_indicator_onnx_model_path": {
                  "type": "string",
                  "default": "$(var data_path)/diffusion_planner/v5.0/diffusion_planner_turn_indicator.onnx",
                  "description": "Path to the turn indicator ONNX model file"
                },
                "dpm_solver_steps": {
                  "type": "integer",
                  "default": 10,
                  "minimum": 2,
                  "description": "Number of DPM-Solver denoising steps. The final denoise-to-zero step is added separately."
                }
              },
              "required": [
                "encoder_onnx_model_path",
                "decoder_onnx_model_path",
                "turn_indicator_onnx_model_path",
                "dpm_solver_steps"
              ]
            }
          },
          "required": [
            "type",
            "args_path",
            "backend",
            "precision",
            "use_cuda_graph",
            "single_step_model",
            "multi_step_model"
          ]
        },
        "planning_frequency_hz": {
          "type": "number",
          "default": 10.0,
          "exclusiveMinimum": 0,
          "description": "Planning frequency in Hz"
        },
        "ignore_neighbors": {
          "type": "boolean",
          "default": false,
          "description": "Ignore neighbor agents"
        },
        "ignore_unknown_neighbors": {
          "type": "boolean",
          "default": true,
          "description": "Ignore neighbor agents with unknown class"
        },
        "traffic_light_group_msg_timeout_seconds": {
          "type": "number",
          "default": 0.2,
          "exclusiveMinimum": 0,
          "description": "Timeout for traffic light group messages (seconds)"
        },
        "build_only": {
          "type": "boolean",
          "default": false,
          "description": "On build only, do not run the planner"
        },
        "batch_size": {
          "type": "integer",
          "default": 1,
          "minimum": 1,
          "description": "Batch size for multi-batch inference"
        },
        "temperature": {
          "type": "array",
          "items": {
            "type": "number",
            "minimum": 0
          },
          "default": [0.0],
          "description": "List of temperature for sampling trajectories. Its length must be the same as `batch_size`. Each value means the coefficient of the standard normal distribution which is used for each initial noise of corresponding batch index. val = N(0,1) * temperature"
        },
        "velocity_smoothing_window": {
          "type": "integer",
          "default": 8,
          "minimum": 1,
          "description": "Window size for velocity smoothing. Set to 1 to disable smoothing."
        },
        "stopping_threshold": {
          "type": "number",
          "default": 0.3,
          "description": "Threshold for keeping the stopping state [m/s]"
        },
        "turn_indicator_keep_offset": {
          "type": "number",
          "default": -1.25,
          "description": "Offset to add to the KEEP turn indicator logit for bias adjustment"
        },
        "turn_indicator_hold_duration": {
          "type": "number",
          "default": 1.0,
          "description": "Duration to hold the turn indicator command before allowing changes (seconds)"
        },
        "shift_x": {
          "type": "boolean",
          "default": false,
          "description": "Whether to shift the ego center position by half the wheel base"
        },
        "delay_step": {
          "type": "integer",
          "default": 0,
          "minimum": 0,
          "description": "Input delay step for inference"
        },
        "line_string_max_step_m": {
          "type": "number",
          "default": 5.0,
          "exclusiveMinimum": 0,
          "description": "Maximum arc-length step per model point when resampling line strings [m]. Smaller values produce more fixed-size sub-segments per line string."
        },
        "use_time_interpolation": {
          "type": "boolean",
          "default": false,
          "description": "Whether to interpolate ego past trajectory at regular time intervals"
        },
        "guidance": {
          "type": "object",
          "properties": {
            "start_guidance": {
              "type": "object",
              "properties": {
                "reference_distance_m": {
                  "type": "number",
                  "default": 10.0,
                  "minimum": 0,
                  "description": "Reference straight-line distance between the ego trajectory start and terminal point [m]"
                },
                "max_scale": {
                  "type": "number",
                  "default": 30.0,
                  "minimum": 1.0,
                  "description": "Maximum scale applied to the ego trajectory by start guidance"
                }
              },
              "required": ["reference_distance_m", "max_scale"]
            },
            "stop_guidance": {
              "type": "object",
              "properties": {
                "stop_acceleration_mps2": {
                  "type": "number",
                  "default": 1.0,
                  "exclusiveMinimum": 0,
                  "description": "Deceleration magnitude used to calculate stop guidance reference distance [m/s^2]"
                }
              },
              "required": ["stop_acceleration_mps2"]
            },
            "centerline_guidance": {
              "type": "object",
              "properties": {
                "start_time_s": {
                  "type": "number",
                  "default": 2.0,
                  "minimum": 0,
                  "description": "Trajectory points at and after this prediction time are snapped to the nearest route centerline point [s]"
                }
              },
              "required": ["start_time_s"]
            }
          },
          "required": ["start_guidance", "stop_guidance", "centerline_guidance"]
        },
        "planning_factor": {
          "type": "object",
          "properties": {
            "enable_stop": {
              "type": "boolean",
              "default": false,
              "description": "Enable stop planning factor"
            },
            "enable_slowdown": {
              "type": "boolean",
              "default": false,
              "description": "Enable slowdown planning factor"
            },
            "stop_velocity_threshold": {
              "type": "number",
              "default": 0.1,
              "description": "Velocity threshold to detect a stop [m/s]"
            },
            "stop_keep_duration_threshold": {
              "type": "number",
              "default": 1.0,
              "description": "Duration threshold to validate a stop [s]"
            },
            "slowdown_accel_threshold": {
              "type": "number",
              "default": -0.3,
              "description": "Acceleration threshold to detect a slowdown [m/s^2]"
            }
          },
          "required": [
            "enable_stop",
            "enable_slowdown",
            "stop_velocity_threshold",
            "stop_keep_duration_threshold",
            "slowdown_accel_threshold"
          ]
        },
        "debug_params": {
          "type": "object",
          "properties": {
            "publish_debug_map": {
              "type": "boolean",
              "default": false,
              "description": "Publish debug map markers"
            },
            "publish_debug_route": {
              "type": "boolean",
              "default": true,
              "description": "Publish debug route markers"
            },
            "publish_debug_linestrings": {
              "type": "boolean",
              "default": true,
              "description": "Publish debug linestring markers"
            }
          },
          "required": ["publish_debug_map", "publish_debug_route", "publish_debug_linestrings"]
        }
      },
      "required": [
        "model",
        "planning_frequency_hz",
        "traffic_light_group_msg_timeout_seconds",
        "batch_size",
        "temperature",
        "velocity_smoothing_window",
        "stopping_threshold",
        "turn_indicator_keep_offset",
        "turn_indicator_hold_duration",
        "planning_factor",
        "debug_params",
        "guidance"
      ]
    }
  },
  "properties": {
    "/**": {
      "type": "object",
      "properties": {
        "ros__parameters": {
          "$ref": "#/definitions/diffusion_planner_node"
        }
      },
      "required": ["ros__parameters"]
    }
  },
  "required": ["/**"]
}
